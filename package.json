{
  "name": "tabnews-curso-dev-study",
  "version": "1.0.0",
  "description": "Repositório criado a partir das aulas do curso.dev para estudo",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "services:up": "docker compose -f infra/compose.yml up -d",
    "services:stop": "docker compose -f infra/compose.yml stop",
    "services:down": "docker compose -f infra/compose.yml down",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "build": "next build",
    "start": "next start",
    "test": "jest --runInBand",
    "test:watch": "jest --watchAll --runInBand",
    "migration:up": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development up",
    "migration:down": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development down",
    "migration:create": "node-pg-migrate --migrations-dir infra/migrations --envPath .env.development create",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "canvas-confetti": "^1.9.4",
    "dotenv": "^16.4.4",
    "framer-motion": "^12.38.0",
    "i": "^0.3.7",
    "lucide-react": "^1.7.0",
    "next": "^13.1.6",
    "node-pg-migrate": "^6.2.2",
    "npm": "^11.14.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-youtube": "^10.1.0"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "prettier": "^3.8.2"
  }
}
